# korin.pink front-door / minified orchestrator.
# Caddy is the single entrypoint; each service is routed by path prefix:
#   /api/*   -> Fastify API container
#   /*       -> the unified Astro static build (landing at /, wiki at /wiki/*,
#               chat at /chat/) served from /srv/web (packages/web/dist)
# New services (e.g. /files, /ai) slot in as additional handle blocks.

{$DOMAIN:localhost} {
    # API — strip the /api prefix before forwarding.
    handle_path /api/* {
        reverse_proxy api:3000
    }

    # Wiki is now part of the Astro build (dist/wiki/**), served by the catch-all
    # file_server below — no separate container/proxy. Normalise /wiki → /wiki/.
    redir /wiki /wiki/

    # Chat — the gamja web IRC client (static, built into packages/web/public/chat
    # by packages/chat/build.sh, copied into dist/chat by `astro build`). Served by
    # the catch-all below; this only normalises /chat → /chat/.
    redir /chat /chat/

    # IRC-over-WebSocket for the gamja client (dev config.json: server.url
    # "/socket"). Reverse-proxied to Ergo's internal plain-ws listener; Caddy
    # terminates TLS at the edge and auto-upgrades the WebSocket.
    handle /socket {
        reverse_proxy ergo:8098
    }

    # Static portal — the front door. Serves everything else (incl. /chat/).
    handle {
        root * /srv/web
        rewrite /irc/feed.xml /feed.xml
        file_server
    }
}
