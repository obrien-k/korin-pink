# korin.pink — copy to .env and fill in. NEVER commit the real .env.
# Required to run the stack; the API/bridge throw on missing required vars.

# ── Domain / proxy ───────────────────────────────────────────────────────────
DOMAIN=localhost                 # korin.pink in prod; localhost for self-host

# ── Stellar integration (stellar-api ADR-0013) ───────────────────────────────
STELLAR_API_URL=
STELLAR_API_KEY=                 # Bearer, for korin → stellar calls
STELLAR_PULL_KEY=                # x-pull-key, stellar → korin (/irc/metrics pull, /irc/announce)

# ── Google Workspace ─────────────────────────────────────────────────────────
GEMINI_API_KEY=
DRIVE_ROOT_FOLDER_ID=
DRIVE_WIKI_FOLDER_ID=
GOOGLE_APPLICATION_CREDENTIALS=./infra/secrets/gcp-service-account.json

# ── irc-bridge ───────────────────────────────────────────────────────────────
IRC_BRIDGE_SECRET=               # x-bridge-secret for POST /irc/metrics (any random string)
IRC_HOST=ergo
IRC_PORT=6697
IRC_TLS=true
IRC_NICK=stellar-bridge
IRC_SASL_USER=                   # Ergo account for the bridge oper bot
IRC_SASL_PASS=
KORIN_API_URL=http://api:3000
FLUSH_INTERVAL_MS=60000
