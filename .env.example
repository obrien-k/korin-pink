# korin.pink — copy to .env and fill in. NEVER commit the real .env.
# Required to run the stack; the API/bridge throw on missing required vars.
# LOCAL DEV ONLY: in production the box .env is rendered by the deploy pipeline
# from GitHub Actions secrets — do not hand-edit it. See docs/deploy/secrets.md.

# ── Domain / proxy ───────────────────────────────────────────────────────────
DOMAIN=localhost                 # korin.pink in prod; localhost for self-host
API_DOMAIN=                      # api.korin.pink in prod — public API host fronted by
                                 # Caddy (docker-compose.prod.yml). Leave empty for local.

# ── Stellar integration (stellar-api ADR-0013) ───────────────────────────────
STELLAR_API_URL=
STELLAR_API_KEY=                 # Bearer, korin → stellar (nick lookup/link/reputation). SAME VALUE as stellar's STELLAR_SERVICE_KEY.
STELLAR_PULL_KEY=                # x-pull-key, stellar → korin (/irc/metrics pull, /irc/announce). SAME VALUE as stellar's KORIN_PULL_KEY.

# ── Google Workspace ─────────────────────────────────────────────────────────
GEMINI_API_KEY=
DRIVE_ROOT_FOLDER_ID=
DRIVE_WIKI_FOLDER_ID=
GOOGLE_APPLICATION_CREDENTIALS=./infra/secrets/gcp-service-account.json

# ── irc-bridge ───────────────────────────────────────────────────────────────
IRC_BRIDGE_SECRET=               # x-bridge-secret for POST /irc/metrics (any random string)
IRC_HOST=ergo
IRC_PORT=6697
IRC_TLS=true
IRC_NICK=stellar-bridge
IRC_SASL_USER=                   # Ergo account for the bridge oper bot
IRC_SASL_PASS=
KORIN_API_URL=http://api:3000
FLUSH_INTERVAL_MS=60000

# ── Ergo (IRC daemon) ────────────────────────────────────────────────────────
# Box-local Ergo config (real oper hashes) mounted OVER the baked template. Create
# it from the template and set hashes via `ergo genpasswd` — see docs/deploy/vps.md
# §6a — then uncomment. Left commented, the compose default mounts the committed
# template (opers have empty passwords → won't boot until you provide real ones).
# ERGO_CONF=./ergo.local.yaml
# TLS_DIR=./tls                    # dir with fullchain.pem/privkey.pem for :6697/:8097
